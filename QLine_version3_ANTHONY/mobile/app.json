{
  "expo": {
    "name": "QLine",
    "slug": "qline",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "qline",
    "platforms": ["ios", "android", "web"],
    "plugins": ["expo-router"],
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "QLine utilise la camera pour scanner les QR codes commerces."
      }
    },
    "android": {
      "permissions": ["CAMERA"]
    }
  }
}
